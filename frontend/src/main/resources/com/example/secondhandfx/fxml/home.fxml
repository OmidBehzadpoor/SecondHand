<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.secondhandfx.controller.HomeController"
            prefWidth="900" prefHeight="650" styleClass="root">

    <top>
        <VBox spacing="10" styleClass="top-bar">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="آگهی‌های فعال" styleClass="title-label"/>
                <HBox HBox.hgrow="ALWAYS"/>

                <Button fx:id="themeToggleButton" text="🌙" onAction="#onToggleThemeClick"
                        styleClass="btn, btn-icon"/>

                <Button text="آگهی‌های من" onAction="#onMyAdvertisementsClick" styleClass="btn"/>
                <Button text="علاقه‌مندی‌ها" onAction="#onFavoritesClick" styleClass="btn"/>
                <Button text="ثبت آگهی جدید" onAction="#onCreateAdvertisementClick" styleClass="btn, btn-primary"/>

                <!-- حالت مهمون: دکمه‌های ورود و ثبت‌نام -->
                <HBox fx:id="guestAuthBox" spacing="8" alignment="CENTER_LEFT">
                    <Button text="ورود" onAction="#onLoginClick" styleClass="btn, btn-success"/>
                    <Button text="ثبت‌نام" onAction="#onRegisterClick" styleClass="btn"/>
                </HBox>

                <!-- حالت لاگین‌شده: نام کاربر و دکمه‌ی خروج -->
                <HBox fx:id="userAuthBox" spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="welcomeLabel" styleClass="muted-label"/>
                    <Button text="خروج" onAction="#onLogoutButtonClick" styleClass="btn, btn-danger"/>
                </HBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="جست‌وجو در عنوان و توضیحات..." prefWidth="220"/>
                <ComboBox fx:id="categoryComboBox" promptText="دسته‌بندی" prefWidth="150"/>
                <ComboBox fx:id="cityComboBox" promptText="شهر" prefWidth="130"/>
                <TextField fx:id="minPriceField" promptText="حداقل قیمت" prefWidth="100"/>
                <TextField fx:id="maxPriceField" promptText="حداکثر قیمت" prefWidth="100"/>
                <ComboBox fx:id="sortComboBox" promptText="مرتب‌سازی" prefWidth="120"/>
                <Button text="اعمال فیلتر" onAction="#onSearchClick" styleClass="btn, btn-success"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-scroll">
            <FlowPane fx:id="advertisementsContainer" hgap="15" vgap="15">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>
            </FlowPane>
        </ScrollPane>
    </center>

    <bottom>
        <HBox spacing="15" alignment="CENTER" styleClass="bottom-bar">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <Button fx:id="prevPageButton" text="◀ قبلی" onAction="#onPrevPageClick" styleClass="btn"/>
            <Label fx:id="pageIndicatorLabel" text="1 از 1"/>
            <Button fx:id="nextPageButton" text="بعدی ▶" onAction="#onNextPageClick" styleClass="btn"/>
        </HBox>
    </bottom>

</BorderPane>