<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.secondhandfx.controller.ChatViewController"
            styleClass="root">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="chat-header">
            <Button text="←" onAction="#onBackClick" styleClass="back-btn-icon"/>
            <Label fx:id="headerLabel" text="" HBox.hgrow="ALWAYS"
                   maxWidth="Infinity" styleClass="chat-title"/>
            <Button fx:id="rateSellerButton" text="امتیازدهی به فروشنده"
                    onAction="#onRateSellerClick" styleClass="btn, btn-warning"/>
        </HBox>
    </top>
    <center>
        <ListView fx:id="messageListView" styleClass="chat-list"/>
    </center>
    <bottom>
        <HBox spacing="8" styleClass="composer">
            <TextField fx:id="messageInputField" promptText="پیام خود را بنویسید..."
                       HBox.hgrow="ALWAYS" styleClass="input"/>
            <Button text="ارسال" onAction="#onSendButtonClick"
                    styleClass="btn, btn-primary"/>
        </HBox>
    </bottom>
</BorderPane>