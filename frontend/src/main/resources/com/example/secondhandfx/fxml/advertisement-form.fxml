<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.secondhandfx.controller.AdvertisementFormController"
            prefWidth="900" prefHeight="650" styleClass="root">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="top-bar">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Label fx:id="pageTitleLabel" text="ثبت آگهی جدید" styleClass="title-label"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-scroll">
            <VBox spacing="15" style="-fx-padding: 20;">

                <VBox spacing="8" styleClass="card">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label text="عنوان آگهی" styleClass="muted-label"/>
                    <TextField fx:id="titleField"/>

                    <Label text="توضیحات" styleClass="muted-label"/>
                    <TextArea fx:id="descriptionArea" prefRowCount="5" wrapText="true"/>

                    <Label text="قیمت (تومان)" styleClass="muted-label"/>
                    <TextField fx:id="priceField"/>

                    <HBox spacing="15">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="دسته‌بندی" styleClass="muted-label"/>
                            <ComboBox fx:id="categoryComboBox" promptText="انتخاب دسته‌بندی" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="شهر" styleClass="muted-label"/>
                            <ComboBox fx:id="cityComboBox" promptText="انتخاب شهر" maxWidth="Infinity"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- فقط در حالت ویرایش نمایش داده می‌شود -->
                <VBox fx:id="existingImagesSection" spacing="8" styleClass="card" visible="false" managed="false">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label text="تصاویر فعلی آگهی" styleClass="muted-label"/>
                    <ListView fx:id="existingImagesListView" prefHeight="120"/>
                </VBox>

                <VBox spacing="8" styleClass="card">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label text="افزودن تصویر جدید" styleClass="muted-label"/>
                    <ListView fx:id="selectedImagesListView" prefHeight="120"/>
                    <HBox spacing="10">
                        <Button text="افزودن تصویر" onAction="#onAddImageClick" styleClass="btn"/>
                        <Button text="حذف تصویر انتخاب‌شده" onAction="#onRemoveImageClick" styleClass="btn"/>
                    </HBox>
                </VBox>

                <HBox spacing="10">
                    <Button fx:id="submitButton" text="ثبت آگهی" onAction="#onSubmitClick" styleClass="btn, btn-primary"/>
                    <Button text="انصراف" onAction="#onCancelClick" styleClass="btn"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>