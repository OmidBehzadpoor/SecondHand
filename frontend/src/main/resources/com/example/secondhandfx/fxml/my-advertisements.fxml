<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.secondhandfx.controller.MyAdvertisementsController"
            styleClass="root">
    <top>
        <VBox spacing="5" styleClass="page-header">
            <Button text="← بازگشت به آگهی‌ها" onAction="#onBackClick" styleClass="back-link"/>
            <Label text="آگهی‌های من" styleClass="page-title"/>
            <Label text="آگهی‌های خود را بر اساس وضعیت مدیریت کنید." styleClass="muted-label"/>
        </VBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" styleClass="tabs">
            <Tab fx:id="approvedTab" text="فعال">
                <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                    <FlowPane fx:id="approvedContainer" hgap="18" vgap="18" styleClass="content"/>
                </ScrollPane>
            </Tab>
            <Tab fx:id="pendingTab" text="در انتظار بررسی">
                <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                    <FlowPane fx:id="pendingContainer" hgap="18" vgap="18" styleClass="content"/>
                </ScrollPane>
            </Tab>
            <Tab fx:id="rejectedTab" text="رد شده">
                <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                    <FlowPane fx:id="rejectedContainer" hgap="18" vgap="18" styleClass="content"/>
                </ScrollPane>
            </Tab>
            <Tab fx:id="soldTab" text="فروخته‌شده">
                <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                    <FlowPane fx:id="soldContainer" hgap="18" vgap="18" styleClass="content"/>
                </ScrollPane>
            </Tab>
            <Tab fx:id="deletedTab" text="حذف‌شده">
                <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                    <FlowPane fx:id="deletedContainer" hgap="18" vgap="18" styleClass="content"/>
                </ScrollPane>
            </Tab>
        </TabPane>
    </center>
</BorderPane>