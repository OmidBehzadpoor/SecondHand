<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.secondhandfx.controller.AdvertisementDetailsController"
            prefWidth="900" prefHeight="650" styleClass="root">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="top-bar">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Button text="بازگشت" onAction="#onBackClick" styleClass="btn"/>
            <Label text="جزئیات آگهی" styleClass="title-label"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="transparent-scroll">
            <VBox spacing="15" style="-fx-padding: 20;">

                <!-- گالری تصاویر -->
                <VBox spacing="8" alignment="CENTER" styleClass="card">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <ImageView fx:id="mainImageView" fitWidth="400" fitHeight="300" preserveRatio="true"/>
                    <HBox spacing="10" alignment="CENTER">
                        <Button fx:id="prevImageButton" text="◀ قبلی" onAction="#onPrevImageClick" styleClass="btn"/>
                        <Label fx:id="imageIndicatorLabel" text="بدون تصویر" styleClass="muted-label"/>
                        <Button fx:id="nextImageButton" text="بعدی ▶" onAction="#onNextImageClick" styleClass="btn"/>
                    </HBox>
                </VBox>

                <!-- اطلاعات اصلی -->
                <VBox spacing="8" styleClass="card">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label fx:id="titleLabel" styleClass="title-label" style="-fx-font-size: 20px;"/>
                    <Label fx:id="priceLabel" styleClass="price-label" style="-fx-font-size: 18px;"/>
                    <Label fx:id="statusLabel" styleClass="muted-label"/>
                    <Label fx:id="rejectionReasonLabel" wrapText="true" styleClass="error-text"
                           style="-fx-padding: 5 0 0 0;"/>

                    <HBox spacing="20">
                        <Label fx:id="cityLabel" styleClass="muted-label"/>
                        <Label fx:id="categoryLabel" styleClass="muted-label"/>
                    </HBox>

                    <Label text="توضیحات:" styleClass="section-label" style="-fx-padding: 10 0 0 0;"/>
                    <Label fx:id="descriptionLabel" wrapText="true" styleClass="muted-label"/>
                </VBox>

                <!-- اطلاعات فروشنده -->
                <VBox spacing="8" styleClass="card">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label fx:id="sellerLabel" styleClass="section-label"/>
                    <Label fx:id="ratingLabel" styleClass="rating-label"/>
                </VBox>

                <!-- دکمه‌های خریدار (پیام به فروشنده / علاقه‌مندی) -->
                <HBox fx:id="buyerActionsBox" spacing="10" styleClass="card">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Button text="پیام به فروشنده" onAction="#onMessageSellerClick" styleClass="btn, btn-primary"/>
                    <Button text="افزودن به علاقه‌مندی‌ها" onAction="#onAddFavoriteClick" styleClass="btn"/>
                </HBox>

                <!-- دکمه‌های صاحب آگهی (ویرایش / حذف / فروخته‌شده) -->
                <HBox fx:id="ownerActionsBox" spacing="10" styleClass="card">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Button text="ویرایش آگهی" onAction="#onEditClick" styleClass="btn, btn-primary"/>
                    <Button fx:id="markAsSoldButton" text="علامت‌گذاری به‌عنوان فروخته‌شده" onAction="#onMarkAsSoldClick"
                            styleClass="btn, btn-warning"/>
                    <Button text="حذف آگهی" onAction="#onDeleteClick" styleClass="btn, btn-danger"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>