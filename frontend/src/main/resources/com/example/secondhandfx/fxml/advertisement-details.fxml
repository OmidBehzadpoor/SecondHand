<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.secondhandfx.controller.AdvertisementDetailsController"
            prefWidth="900" prefHeight="650" style="-fx-background-color: #f4f4f4;">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15;">
            <Button text="بازگشت" onAction="#onBackClick"
                    style="-fx-background-color: #ecf0f1; -fx-padding: 6 14;"/>
            <Label text="جزئیات آگهی" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="15" style="-fx-padding: 20;">

                <!-- گالری تصاویر -->
                <VBox spacing="8" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 15;">
                    <ImageView fx:id="mainImageView" fitWidth="400" fitHeight="300" preserveRatio="true"/>
                    <HBox spacing="10" alignment="CENTER">
                        <Button fx:id="prevImageButton" text="◀ قبلی" onAction="#onPrevImageClick"/>
                        <Label fx:id="imageIndicatorLabel" text="بدون تصویر"/>
                        <Button fx:id="nextImageButton" text="بعدی ▶" onAction="#onNextImageClick"/>
                    </HBox>
                </VBox>

                <!-- اطلاعات اصلی -->
                <VBox spacing="8" style="-fx-background-color: white; -fx-padding: 15;">
                    <Label fx:id="titleLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Label fx:id="priceLabel" style="-fx-font-size: 18px; -fx-text-fill: #27ae60; -fx-font-weight: bold;"/>
                    <Label fx:id="statusLabel" style="-fx-text-fill: #7f8c8d;"/>

                    <HBox spacing="20">
                        <Label fx:id="cityLabel"/>
                        <Label fx:id="categoryLabel"/>
                    </HBox>

                    <Label text="توضیحات:" style="-fx-font-weight: bold; -fx-padding: 10 0 0 0;"/>
                    <Label fx:id="descriptionLabel" wrapText="true"/>
                </VBox>

                <!-- اطلاعات فروشنده -->
                <VBox spacing="8" style="-fx-background-color: white; -fx-padding: 15;">
                    <Label fx:id="sellerLabel" style="-fx-font-weight: bold;"/>
                    <Label fx:id="ratingLabel" style="-fx-text-fill: #f39c12;"/>
                </VBox>

                <!-- دکمه‌های خریدار (پیام به فروشنده / علاقه‌مندی) -->
                <HBox fx:id="buyerActionsBox" spacing="10" style="-fx-background-color: white; -fx-padding: 15;">
                    <Button text="پیام به فروشنده" onAction="#onMessageSellerClick"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 8 16;"/>
                    <Button text="افزودن به علاقه‌مندی‌ها" onAction="#onAddFavoriteClick"
                            style="-fx-background-color: #ecf0f1; -fx-padding: 8 16;"/>
                </HBox>

                <!-- دکمه‌های صاحب آگهی (ویرایش / حذف / فروخته‌شده) -->
                <HBox fx:id="ownerActionsBox" spacing="10" style="-fx-background-color: white; -fx-padding: 15;">
                    <Button text="ویرایش آگهی" onAction="#onEditClick"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 8 16;"/>
                    <Button fx:id="markAsSoldButton" text="علامت‌گذاری به‌عنوان فروخته‌شده" onAction="#onMarkAsSoldClick"
                            style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-padding: 8 16;"/>
                    <Button text="حذف آگهی" onAction="#onDeleteClick"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 8 16;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>