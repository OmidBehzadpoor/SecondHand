<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.secondhandfx.controller.AdvertisementCardController"
      fx:id="root" spacing="6" prefWidth="260" prefHeight="230"
      onMouseClicked="#onCardClick" styleClass="card"
      style="-fx-cursor: hand; -fx-padding: 12;">

    <ImageView fx:id="imageView" fitWidth="230" fitHeight="130" preserveRatio="true" style="-fx-background-color: -color-surface-alt; -fx-background-radius: 6;"/>
    <Label fx:id="titleLabel" styleClass="title-label" style="-fx-font-size: 14px;" wrapText="true"/>
    <Label fx:id="priceLabel" styleClass="price-label" style="-fx-font-size: 14px;"/>
    <Label fx:id="categoryLabel" styleClass="muted-label" style="-fx-font-size: 12px;"/>
    <Label fx:id="cityLabel" styleClass="muted-label" style="-fx-font-size: 12px;"/>
    <Label fx:id="ratingLabel" styleClass="rating-label" style="-fx-font-size: 12px;"/>

</VBox>