<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.secondhandfx.controller.MyAdvertisementCardController"
      fx:id="root" prefWidth="400" spacing="10" styleClass="compact-card">
    <HBox>
        <Label fx:id="statusBadgeLabel" text="" styleClass="status-badge"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="آگهی من" styleClass="eyebrow"/>
    </HBox>
    <Label fx:id="titleLabel" wrapText="true" styleClass="card-title"/>
    <Label fx:id="priceLabel" styleClass="card-price"/>
    <Label fx:id="rejectionReasonLabel" text="" wrapText="true" styleClass="danger-note"/>
    <Separator/>
    <HBox spacing="6">
        <Button fx:id="viewButton" text="مشاهده" onAction="#onViewClick" styleClass="btn" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button fx:id="editButton" text="ویرایش" onAction="#onEditClick" styleClass="btn, btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button fx:id="markAsSoldButton" text="فروخته شد" onAction="#onMarkAsSoldClick" styleClass="btn, btn-warning" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button fx:id="deleteButton" text="حذف" onAction="#onDeleteClick" styleClass="btn, btn-danger" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    </HBox>
</VBox>