<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.secondhandfx.controller.AdminPanelController"
            styleClass="root">
    <top>
        <HBox alignment="CENTER_RIGHT" styleClass="top-bar">
            <Button text="← بازگشت به آگهی‌ها" onAction="#onBackClick" styleClass="back-link"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox spacing="3">
                <Label text="مدیریت سامانه" styleClass="eyebrow"/>
                <Label text="پنل ادمین" styleClass="page-title"/>
            </VBox>
        </HBox>
    </top>
    <center>
        <TabPane fx:id="adminTabPane" tabClosingPolicy="UNAVAILABLE" styleClass="tabs">
            <Tab text="نمای کلی">
                <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                    <FlowPane fx:id="statsContainer" hgap="16" vgap="16" styleClass="content"/>
                </ScrollPane>
            </Tab>
            <Tab text="آگهی‌های در انتظار بررسی">
                <VBox styleClass="content">
                    <TableView fx:id="pendingAdsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="adTitleColumn" text="عنوان" prefWidth="260"/>
                            <TableColumn fx:id="adSellerColumn" text="فروشنده" prefWidth="160"/>
                            <TableColumn fx:id="adPriceColumn" text="قیمت" prefWidth="150"/>
                            <TableColumn fx:id="adActionsColumn" text="عملیات" prefWidth="400"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
            <Tab text="همه آگهی‌ها">
                <VBox styleClass="content">
                    <TableView fx:id="allAdsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="allAdTitleColumn" text="عنوان" prefWidth="260"/>
                            <TableColumn fx:id="allAdSellerColumn" text="فروشنده" prefWidth="160"/>
                            <TableColumn fx:id="allAdPriceColumn" text="قیمت" prefWidth="150"/>
                            <TableColumn fx:id="allAdStatusColumn" text="وضعیت" prefWidth="150"/>
                            <TableColumn fx:id="allAdActionsColumn" text="عملیات" prefWidth="220"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
            <Tab text="کاربران">
                <VBox styleClass="content">
                    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="userNameColumn" text="نام کاربری" prefWidth="220"/>
                            <TableColumn fx:id="userRoleColumn" text="نقش" prefWidth="140"/>
                            <TableColumn fx:id="userStatusColumn" text="وضعیت" prefWidth="140"/>
                            <TableColumn fx:id="userActionsColumn" text="عملیات" prefWidth="250"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
            <Tab text="دسته‌بندی‌ها و شهرها">
                <HBox spacing="18" styleClass="content">
                    <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="admin-card">
                        <Label text="دسته‌بندی‌ها" styleClass="section-title-small"/>
                        <HBox spacing="8">
                            <TextField fx:id="newCategoryField" promptText="دسته‌بندی جدید" styleClass="input" HBox.hgrow="ALWAYS"/>
                            <ComboBox fx:id="parentCategoryComboBox" promptText="دسته والد" prefWidth="180"/>
                            <Button text="افزودن" onAction="#onAddCategoryClick" styleClass="btn, btn-primary"/>
                        </HBox>
                        <TableView fx:id="categoriesTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="categoryNameColumn" text="نام" prefWidth="220"/>
                                <TableColumn fx:id="categoryActionsColumn" text="عملیات" prefWidth="220"/>
                            </columns>
                        </TableView>
                    </VBox>
                    <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="admin-card">
                        <Label text="شهرها" styleClass="section-title-small"/>
                        <HBox spacing="8">
                            <TextField fx:id="newCityField" promptText="شهر جدید" styleClass="input" HBox.hgrow="ALWAYS"/>
                            <Button text="افزودن" onAction="#onAddCityClick" styleClass="btn, btn-primary"/>
                        </HBox>
                        <TableView fx:id="citiesTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="cityNameColumn" text="نام" prefWidth="220"/>
                                <TableColumn fx:id="cityActionsColumn" text="عملیات" prefWidth="160"/>
                            </columns>
                        </TableView>
                    </VBox>
                </HBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>