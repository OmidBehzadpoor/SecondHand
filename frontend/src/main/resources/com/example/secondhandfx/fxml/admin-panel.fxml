<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.secondhandfx.controller.AdminPanelController"
            prefWidth="800" prefHeight="550">

    <!-- ====== نوار بالایی با دکمه‌ی بازگشت و عنوان ====== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 10 15;">
            <Button text="← بازگشت" onAction="#onBackClick"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"/>
            <Label text="پنل ادمین"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <!-- ====== محتوای اصلی (همان TabPane قبلی) ====== -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-padding: 10;">

            <Tab text="آگهی‌های در انتظار بررسی">
                <TableView fx:id="pendingAdsTable">
                    <columns>
                        <TableColumn fx:id="adTitleColumn" text="عنوان" prefWidth="180"/>
                        <TableColumn fx:id="adSellerColumn" text="فروشنده" prefWidth="120"/>
                        <TableColumn fx:id="adPriceColumn" text="قیمت" prefWidth="100"/>
                        <TableColumn fx:id="adActionsColumn" text="عملیات" prefWidth="200"/>
                    </columns>
                </TableView>
            </Tab>

            <Tab text="کاربران">
                <TableView fx:id="usersTable">
                    <columns>
                        <TableColumn fx:id="userNameColumn" text="نام کاربری" prefWidth="140"/>
                        <TableColumn fx:id="userRoleColumn" text="نقش" prefWidth="100"/>
                        <TableColumn fx:id="userStatusColumn" text="وضعیت" prefWidth="100"/>
                        <TableColumn fx:id="userActionsColumn" text="عملیات" prefWidth="160"/>
                    </columns>
                </TableView>
            </Tab>

            <Tab text="دسته‌بندی‌ها و شهرها">
                <HBox spacing="20" style="-fx-padding: 15;">

                    <VBox spacing="10" HBox.hgrow="ALWAYS">
                        <Label text="دسته‌بندی‌ها" style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                        <HBox spacing="8">
                            <TextField fx:id="newCategoryField" promptText="نام دسته‌بندی جدید" HBox.hgrow="ALWAYS"/>
                            <Button text="افزودن" onAction="#onAddCategoryClick"/>
                        </HBox>
                        <TableView fx:id="categoriesTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="categoryNameColumn" text="نام" prefWidth="140"/>
                                <TableColumn fx:id="categoryActionsColumn" text="عملیات" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <VBox spacing="10" HBox.hgrow="ALWAYS">
                        <Label text="شهرها" style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                        <HBox spacing="8">
                            <TextField fx:id="newCityField" promptText="نام شهر جدید" HBox.hgrow="ALWAYS"/>
                            <Button text="افزودن" onAction="#onAddCityClick"/>
                        </HBox>
                        <TableView fx:id="citiesTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="cityNameColumn" text="نام" prefWidth="140"/>
                                <TableColumn fx:id="cityActionsColumn" text="عملیات" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </VBox>

                </HBox>
            </Tab>

        </TabPane>
    </center>

</BorderPane>