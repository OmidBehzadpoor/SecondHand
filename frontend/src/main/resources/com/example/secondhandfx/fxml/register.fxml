<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="480.0" prefWidth="400.0" spacing="10" alignment="TOP_CENTER"
      xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.secondhandfx.controller.RegisterController"
      style="-fx-background-color: #f4f4f4;">
   <padding>
      <Insets top="20" right="30" bottom="20" left="30"/>
   </padding>
   <children>
      <Label text="ثبت‌نام" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

      <Label text="نام و نام خانوادگی"/>
      <TextField fx:id="nameField"/>

      <Label text="نام کاربری"/>
      <TextField fx:id="usernameField"/>

      <Label text="رمز عبور"/>
      <PasswordField fx:id="passwordField"/>

      <Label text="شماره تماس"/>
      <TextField fx:id="phoneField"/>

      <Label text="ایمیل"/>
      <TextField fx:id="emailField"/>

      <Button text="ثبت‌نام" onAction="#onRegisterButtonClick"
              style="-fx-font-size: 14px; -fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 8 30;"/>

      <Hyperlink fx:id="loginLink" text="قبلاً ثبت‌نام کرده‌اید؟ ورود" onAction="#onLoginLinkClick"/>
   </children>
</VBox>
