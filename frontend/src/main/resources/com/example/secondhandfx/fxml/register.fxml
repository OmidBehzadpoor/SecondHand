<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="480.0" prefWidth="400.0" spacing="10" alignment="TOP_CENTER"
      xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.secondhandfx.controller.RegisterController"
      styleClass="root">
   <padding>
      <Insets top="20" right="30" bottom="20" left="30"/>
   </padding>
   <children>
      <Button text="← بازگشت به صفحه اصلی" onAction="#onBackToHomeClick" styleClass="back-link"/>
      <Label text="ثبت‌نام" styleClass="page-title"/>

      <Label text="نام و نام خانوادگی" styleClass="muted-label"/>
      <TextField fx:id="nameField"/>

      <Label text="نام کاربری" styleClass="muted-label"/>
      <TextField fx:id="usernameField"/>

      <Label text="رمز عبور" styleClass="muted-label"/>
      <PasswordField fx:id="passwordField"/>

      <Label text="شماره تماس" styleClass="muted-label"/>
      <TextField fx:id="phoneField"/>

      <Label text="ایمیل" styleClass="muted-label"/>
      <TextField fx:id="emailField"/>

      <Button text="ثبت‌نام" onAction="#onRegisterButtonClick" styleClass="btn, btn-primary"/>

      <Hyperlink fx:id="loginLink" text="قبلاً ثبت‌نام کرده‌اید؟ ورود" onAction="#onLoginLinkClick"/>
   </children>
</VBox>
