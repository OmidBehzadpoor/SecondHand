<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.secondhandfx.controller.ConversationListController"
      styleClass="root">
    <HBox alignment="CENTER_RIGHT" styleClass="top-bar">
        <Button text="← بازگشت" onAction="#onBackClick" styleClass="back-btn"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="گفتگوهای من" styleClass="page-title"/>
    </HBox>
    <StackPane VBox.vgrow="ALWAYS">
        <ListView fx:id="conversationListView" styleClass="conversation-list"/>
    </StackPane>
</VBox>